ions": [\n    {\n      "evidence1": "High error ratios suggest service unavailability",\n      "evidence2": "Infrastructure metrics (pod_cpu_usage, pod_processes) unavailable for verification",\n      "verification_needed": "Need to check logs or other availability indicators to confirm if pods are running but failing requests, or if pods have actually crashed"\n    }\n  ],\n  "next_verification": {\n    "action": "check_logs",\n    "reason": "High error ratios without infrastructure metrics require log analysis to determine root cause",\n    "suggested_metrics": [],\n    "suggested_log_keywords": ["error", "exception", "timeout", "connection refused", "OOMKilled"]\n  }\n}\n```'}
